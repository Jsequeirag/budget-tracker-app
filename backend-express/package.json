{
  "name": "backend-express",
  "version": "1.0.0",
  "description": "Backend template con TypeScript, Express.js, JWT y Prisma + MongoDB",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch src/server.ts",
    "dev:nodemon": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon",
    "dev:node": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 node --watch dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 prisma generate",
    "db:push": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 prisma db push",
    "db:studio": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 prisma studio",
    "seed": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "envalid": "^8.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.8",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  }
}
